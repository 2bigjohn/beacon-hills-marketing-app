{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "build": {
    "env": {
      "VITE_USE_PROXY": "true",
      "BASE_PATH": "/"
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  }
}
